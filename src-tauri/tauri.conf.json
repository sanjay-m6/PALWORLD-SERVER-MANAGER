{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Palworld Server Manager",
  "version": "1.6.0",
  "identifier": "com.palworld.servermanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Palworld Server Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "center": true,
        "decorations": false,
        "additionalBrowserArgs": "--disable-features=AudioServiceOutOfProcess,HardwareMediaKeyHandling,MediaSessionService --disable-speech-api --renderer-process-limit=1"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "en-US"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMEFGOEE3RUY0RTgxMDYKUldRR2dVN3ZwL2dLOFBkOFBNaERWMDNjQ3BRa0tlUXVqSDVYMXFRQkxrKzZGZC94NkFYeEJoRkgK",
      "endpoints": [
        "https://github.com/sanjay-m6/PALWORLD-SERVER-MANAGER/releases/latest/download/latest.json"
      ]
    }
  }
}